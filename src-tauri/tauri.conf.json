{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LLM Notch",
  "version": "0.1.2",
  "identifier": "com.llmnotch.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build && npm run native:prepare-helper",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "LLM Notch",
        "width": 360,
        "height": 44,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": false,
        "acceptFirstMouse": true
      },
      {
        "label": "dashboard",
        "title": "LLM Notch Dashboard",
        "width": 900,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc:; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/llm-notch-hook", "binaries/llm-notch-relay"],
    "resources": {
      "../integrations/": "integrations/",
      "binaries/llm-notch-relay-*": "binaries/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
