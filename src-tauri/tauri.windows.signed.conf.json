{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "windows": {
      "digestAlgorithm": "sha256",
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-NoLogo",
          "-NoProfile",
          "-NonInteractive",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "& (Join-Path $env:GITHUB_WORKSPACE 'scripts/signing/sign-windows.ps1') -ArtifactPath '%1'"
        ]
      }
    }
  }
}
