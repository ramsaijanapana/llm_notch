{
  "_comment": "TEMPLATE ONLY — requires explicit user trust via Codex /hooks. Enable with: codex -c features.hooks=true (features.codex_hooks is deprecated). {{LLM_NOTCH_HELPER}} is replaced with the bundled helper absolute path at install time.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source codex --vendor-event SessionStart",
            "statusMessage": "llm_notch: session observe",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source codex --vendor-event PreToolUse",
            "statusMessage": "llm_notch: tool observe",
            "timeout": 2
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source codex --vendor-event PermissionRequest",
            "statusMessage": "llm_notch: permission observe",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source codex --vendor-event PostToolUse",
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source codex --vendor-event UserPromptSubmit",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source codex --vendor-event Stop",
            "statusMessage": "llm_notch: turn observe",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
