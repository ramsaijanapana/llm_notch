{
  "version": 1,
  "_comment": "TEMPLATE ONLY — not installed automatically. Review diff before applying. {{LLM_NOTCH_HELPER}} is replaced at install time with the absolute bundled helper path.",
  "hooks": {
    "sessionStart": [
      {
        "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source cursor --vendor-event sessionStart --hook-mode",
        "timeout": 2
      }
    ],
    "preToolUse": [
      {
        "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source cursor --vendor-event preToolUse --hook-mode",
        "timeout": 2
      }
    ],
    "postToolUse": [
      {
        "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source cursor --vendor-event postToolUse --hook-mode",
        "timeout": 2
      }
    ],
    "postToolUseFailure": [
      {
        "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source cursor --vendor-event postToolUseFailure --hook-mode",
        "timeout": 2
      }
    ],
    "stop": [
      {
        "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source cursor --vendor-event stop --hook-mode",
        "timeout": 2
      }
    ],
    "sessionEnd": [
      {
        "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source cursor --vendor-event sessionEnd --hook-mode",
        "timeout": 2
      }
    ]
  }
}
