{
  "_comment": "TEMPLATE FRAGMENT — merge only the hooks object into .claude/settings.json or ~/.claude/settings.json. Preserve permissions, model, env, and unrelated settings. {{LLM_NOTCH_HELPER}} is substituted with the bundled helper absolute path at install time.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source claudeCode --vendor-event SessionStart --hook-mode",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source claudeCode --vendor-event PreToolUse --hook-mode",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source claudeCode --vendor-event PostToolUse --hook-mode",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source claudeCode --vendor-event PostToolUseFailure --hook-mode",
            "timeout": 2
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source claudeCode --vendor-event PermissionRequest --hook-mode",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source claudeCode --vendor-event Stop --hook-mode",
            "timeout": 2
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{LLM_NOTCH_HELPER}}\" hook --source claudeCode --vendor-event SessionEnd --hook-mode",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
